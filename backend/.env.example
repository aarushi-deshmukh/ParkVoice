# Application
APP_NAME="ParkVoice AI"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgresql://neondb_owner:npg_3slUunb7XWxf@ep-raspy-bread-aq6flwei-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Production example: postgresql+asyncpg://USER:PASSWORD@HOST/neondb?ssl=require

# File Storage
UPLOAD_DIR=./uploads
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=voice-recordings
MAX_UPLOAD_SIZE_MB=50
ALLOWED_AUDIO_FORMATS=wav,mp3,m4a,ogg,flac

# Model Paths
MODEL_DIR=./models
ENSEMBLE_MODEL_PATH=./models/ensemble_model.pkl
SEVERITY_MODEL_PATH=./models/severity_model.pkl
CNN_MODEL_PATH=./models/cnn_model.pt
ONNX_MODEL_PATH=./models/ensemble_quantized.onnx

# Feature Extraction
SAMPLE_RATE=22050
N_MFCC=40
N_MELS=128
HOP_LENGTH=512
N_FFT=2048

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Device (auto, cpu, cuda)
DEVICE=auto
